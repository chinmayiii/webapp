pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/chinmayiii/webapp'
            }
        }

        stage('Build WAR') {
            steps {
                dir('2023MavenWebAppPe') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Deploy Tomcat') {
            steps {
                dir('2023MavenWebAppPe') {
                    sh 'cp target/*.war /opt/tomcat/webapps/'
                }
            }
        }

        stage('Verify') {
            steps {
                sh 'ls /opt/tomcat/webapps'
            }
        }
    }

    post {

        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed'
        }
    }
}
